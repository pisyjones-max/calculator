# Скопируйте этот файл в .env и заполните реальными значениями.
# .env не коммитится в git (см. .gitignore).

# Telegram-бот для уведомлений о новых заявках с калькулятора.
# Токен — получить у @BotFather. Chat ID — id менеджера или группы,
# куда должны приходить заявки (можно узнать через @userinfobot).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Публичный домен backend — используется только чтобы вставить прямую
# ссылку на PDF сметы в текст уведомления. Например: https://platforma-msk.ru
# Можно оставить пустым — ссылка просто не будет добавлена в сообщение.
PUBLIC_BASE_URL=

# CORS: разрешённые домены через запятую, например:
# ALLOWED_ORIGINS=https://platforma-msk.ru,https://www.platforma-msk.ru
# Если не задано — CORS открыт на "*" (ок для первого деплоя, но после
# того как домены калькулятора/виджета определятся — сузьте до них).
ALLOWED_ORIGINS=

# Если не задано — используется локальный SQLite-файл platforma.db.
# На Render/Railway с эфемерным диском между деплоями рекомендуется Postgres
# (см. DEPLOY.md), тогда сюда указывается строка подключения:
# DATABASE_URL=postgresql://user:password@host:5432/platforma
DATABASE_URL=
